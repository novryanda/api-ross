# ============================================================
# ROSS/BuzzTrack Backend – Environment Variables
# Untuk Dokploy: masukkan semua env di panel Dokploy.
# File ini hanya sebagai referensi/template.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@db-host:5432/ross_db?schema=public"

# ── Better Auth ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="https://api.yourdomain.com"
TRUSTED_ORIGINS="https://yourdomain.com,https://api.yourdomain.com"

# ── Startup Flags ────────────────────────────────────────────
# Set to "false" to skip on container start. Default: true.
RUN_MIGRATE_ON_STARTUP=true
RUN_SEED_ON_STARTUP=true

# ── Seed Config ──────────────────────────────────────────────
SEED_ORG_NAME="ROSS Organization"
SEED_ORG_SLUG="ross-org"
SEED_ADMIN_NAME="ROSS Admin"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# ── Export ───────────────────────────────────────────────────
EXPORT_PROCESSING_TIMEOUT_MINUTES=10

# ── Cloudflare R2 (required) ────────────────────────────────
R2_ACCOUNT_ID="<cloudflare_account_id>"
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
R2_BUCKET="ross-project"
R2_ACCESS_KEY_ID="<access_key_id>"
R2_SECRET_ACCESS_KEY="<secret_access_key>"
R2_PUBLIC_BASE_URL=""
R2_FORCE_PATH_STYLE=true
