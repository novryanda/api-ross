# ============================================================
# ROSS/BuzzTrack Backend – Environment Variables
# Copy to .env and fill in production values
# ============================================================

# ── Core ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database (existing PostgreSQL, no local container) ───────
# Point to your Dokploy/VPS PostgreSQL instance
DATABASE_URL="postgresql://user:password@db-host:5432/ross_db?schema=public"

# ── Better Auth ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
# Public URL of the backend API (used for cookie domain/origin)
BETTER_AUTH_URL="https://api.yourdomain.com"
# Comma-separated list of allowed origins (frontend + backend)
TRUSTED_ORIGINS="https://yourdomain.com,https://api.yourdomain.com"

# ── Seed (initial admin account – run once) ──────────────────
SEED_ORG_NAME="ROSS Organization"
SEED_ORG_SLUG="ross-org"
SEED_ADMIN_NAME="ROSS Admin"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# ── Export Storage ───────────────────────────────────────────
# Driver: "local" for filesystem, "r2" for Cloudflare R2
EXPORT_STORAGE_DRIVER="r2"
# Local fallback directory (absolute path or relative to CWD)
EXPORT_STORAGE_DIR="./storage/exports"
# PROCESSING exports older than this are marked FAILED
EXPORT_PROCESSING_TIMEOUT_MINUTES=10

# ── Cloudflare R2 (required when EXPORT_STORAGE_DRIVER=r2) ──
R2_ENABLED=true
R2_ACCOUNT_ID="<cloudflare_account_id>"
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
R2_BUCKET="ross-project"
R2_ACCESS_KEY_ID="<access_key_id>"
R2_SECRET_ACCESS_KEY="<secret_access_key>"
R2_PUBLIC_BASE_URL=""
R2_FORCE_PATH_STYLE=true
